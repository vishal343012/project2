name: Deploy Static Website to IIS

on:
  push:
    branches: [ "main" ]

jobs:
  deploy:
    runs-on: self-hosted

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Deploy Website to IIS
        run: |
          robocopy . "C:\inetpub\wwwroot" /MIR

      - name: Restart IIS
        run: |
          iisreset
